# ─────────────────────────────────────────────────────────────
# OFD Scheduler - Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────
PORT=3000
BASE_URL=http://your-server-hostname:3000

# Secret used to authenticate the automated Task Scheduler cron calls.
# Set this to a long random string (e.g. output of: openssl rand -hex 32)
NOTIFY_CRON_SECRET=replace-with-random-string

# ── Mailgun (email reminders) ─────────────────────────────────
# Sign in at https://app.mailgun.com/ to find these values.
MAILGUN_API_KEY=
MAILGUN_DOMAIN=mg.yourdomain.com
# The "From" address shown in reminder emails (must be an authorized sender in Mailgun)
MAILGUN_FROM=OFD Checks <checks@mg.yourdomain.com>

# ── FirstDue (auto-sync completed checks) ─────────────────────
# Obtain your API key from your FirstDue department admin or support.
FIRSTDUE_API_KEY=
# Base URL for the FirstDue REST API (no trailing slash)
FIRSTDUE_BASE_URL=https://api.firstdue.com
